      "type": "boolean",
      "description": "Whether the customer returned to an IVR flow or pressed 0."
    },
    "handoff_reason": {
      "type": "string",
      "description": "The reason for handoff to a human agent. NONE if AI resolved without handoff. CUSTOMER_REQUEST if the customer asked to speak to a human. LACK_OF_COMPREHENSION if the AI failed to understand what the customer wanted. LACK_OF_KNOWLEDGE if the AI understood the request but didn't have enough information to answer.",
      "enum": ["NONE", "CUSTOMER_REQUEST", "LACK_OF_COMPREHENSION", "LACK_OF_KNOWLEDGE"]
    },
    "inferred_csat": {
      "type": "integer",
      "description": "Satisfaction score 1-5. 1=very dissatisfied, 5=very satisfied."
    },
    "csat_reasoning": {
      "type": "string",
      "description": "Brief explanation of why this CSAT score was inferred. Reference specific moments in the conversation that influenced the score (e.g., customer frustration, quick resolution, repeated issues)."
    },
    "errors": {
      "type": "boolean",
      "description": "Whether the AI made mistakes (hallucinations, misconceptions, misunderstandings)."
