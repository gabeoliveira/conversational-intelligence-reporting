# AWS Credentials (Option 1: Direct credentials)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_REGION=us-east-1

# AWS Credentials (Option 2: Use a named profile)
# AWS_PROFILE=your-profile-name

# Deployment Configuration
AWS_REGION=us-east-1
CIRL_ENV=dev

# Analytics mode: "none", "simple", or "lakehouse" (default: none)
#   none      — REST API only. No Athena. Best for POCs, Grafana, Flex plugins.
#   simple    — Athena queries DynamoDB directly via federated query.
#               Best for SQL-based BI tools and <100K conversations/month.
#   lakehouse — Glue ETL transforms data into S3 Parquet (Bronze→Silver→Gold).
#               Faster and cheaper Athena queries. Best for >100K conversations/month.
# CIRL_ANALYTICS=none

# API authentication: "none" or "apikey" (default: none)
#   none   — No authentication. Anyone with the URL can access the API.
#   apikey — Requires x-api-key header on all dashboard endpoints.
#            Webhook endpoint stays open for Twilio. API key created automatically.
# CIRL_AUTH=none

# Optional: Override default tenant for single-tenant deployments
# CIRL_TENANT_ID=my-company

# Twilio Credentials (required for fetching CI operator results)
# Found in Twilio Console: https://console.twilio.com
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Skip Twilio webhook signature validation (for testing only)
# SKIP_SIGNATURE_VALIDATION=true
