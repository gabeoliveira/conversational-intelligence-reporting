<?xml version='1.0' encoding='utf-8' ?>

<!-- CIRL Conversational Intelligence Dashboard for Tableau -->
<!--
  This is a simplified Tableau workbook template for CIRL analytics using Athena Federated Query.

  Before opening:
  1. Replace {REGION} with your AWS region (e.g., us-east-1)
  2. Replace {ENV} with your environment (e.g., demo)
  3. Replace {ACCOUNT} with your AWS account ID
  4. Replace {TENANT_ID} with your tenant ID
  5. Replace {TABLE_NAME} with your DynamoDB table name (e.g., cirl-demo)

  Connection requirements:
  - Amazon Athena ODBC driver installed
  - AWS credentials configured with Athena access
  - Athena workgroup: cirl-{env}
  - DynamoDB connector catalog: cirl_dynamo_{env}
  - Database: default
-->

<workbook source-build='2021.4.3 (20214.22.0114.1327)' source-platform='mac' version='18.1' xmlns:user='http://www.tableausoftware.com/xml/user'>
  <preferences>
    <preference name='ui.encoding.shelf.height' value='24' />
    <preference name='ui.shelf.height' value='26' />
  </preferences>

  <datasources>
    <!-- Athena Connection for Metrics -->
    <datasource caption='CIRL Metrics' inline='true' name='athena.cirl_metrics' version='18.1'>
      <connection class='awsathena' dbname='cirl_{ENV}' odbc-native-protocol='yes' one-time-sql='' port='443' server='athena.{REGION}.amazonaws.com' username=''>
        <connection-customization class='awsathena' enabled='false' version='18.1'>
          <vendor name='awsathena' />
          <driver name='awsathena' />
          <customizations>
            <customization name='S3OutputLocation' value='s3://cirl-athena-{ENV}-{ACCOUNT}-{REGION}/results/' />
            <customization name='WorkGroup' value='cirl-{ENV}' />
          </customizations>
        </connection-customization>

        <relation name='Custom SQL Query' type='text'>
          SELECT
            regexp_extract(PK, 'TENANT#([^#]+)', 1) as tenant_id,
            regexp_extract(SK, 'DAY#(\d{8})', 1) as date_str,
            regexp_extract(SK, 'METRIC#(.+)', 1) as metric_name,
            value as metric_value
          FROM "cirl_dynamo_{ENV}".default."{TABLE_NAME}"
          WHERE PK LIKE 'TENANT#{TENANT_ID}#AGG#DAY'
            AND regexp_extract(SK, 'DAY#(\d{8})', 1) &gt;= format_datetime(current_date - interval '30' day, 'yyyyMMdd')
          ORDER BY regexp_extract(SK, 'DAY#(\d{8})', 1) DESC
        </relation>

        <metadata-records>
          <metadata-record class='column'>
            <remote-name>tenant_id</remote-name>
            <remote-type>129</remote-type>
            <local-name>[tenant_id]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>tenant_id</remote-alias>
            <ordinal>1</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>date_str</remote-name>
            <remote-type>129</remote-type>
            <local-name>[date_str]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>date_str</remote-alias>
            <ordinal>2</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
            <calculation class='tableau' formula='DATE(LEFT([date_str], 4) + &quot;-&quot; + MID([date_str], 5, 2) + &quot;-&quot; + RIGHT([date_str], 2))' />
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>metric_name</remote-name>
            <remote-type>129</remote-type>
            <local-name>[metric_name]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>metric_name</remote-alias>
            <ordinal>3</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>metric_value</remote-name>
            <remote-type>5</remote-type>
            <local-name>[metric_value]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>metric_value</remote-alias>
            <ordinal>4</ordinal>
            <local-type>real</local-type>
            <aggregation>Sum</aggregation>
            <precision>15</precision>
            <contains-null>true</contains-null>
          </metadata-record>
        </metadata-records>
      </connection>

      <column datatype='date' name='[date]' role='dimension' type='ordinal' />
      <column datatype='string' name='[metric_name]' role='dimension' type='nominal' />
      <column datatype='real' name='[metric_value]' role='measure' type='quantitative' />
      <column datatype='string' name='[tenant_id]' role='dimension' type='nominal' />
    </datasource>

    <!-- Athena Connection for Conversations -->
    <datasource caption='CIRL Conversations' inline='true' name='athena.cirl_conversations' version='18.1'>
      <connection class='awsathena' dbname='cirl_{ENV}' odbc-native-protocol='yes' one-time-sql='' port='443' server='athena.{REGION}.amazonaws.com' username=''>
        <connection-customization class='awsathena' enabled='false' version='18.1'>
          <vendor name='awsathena' />
          <driver name='awsathena' />
          <customizations>
            <customization name='S3OutputLocation' value='s3://cirl-athena-{ENV}-{ACCOUNT}-{REGION}/results/' />
            <customization name='WorkGroup' value='cirl-{ENV}' />
          </customizations>
        </connection-customization>

        <relation name='Custom SQL Query' type='text'>
          SELECT
            conversation_id,
            tenant_id,
            customer_key,
            agent_id,
            started_at,
            channel_type,
            operator_count
          FROM conversations_clean
          WHERE tenant_id = '{TENANT_ID}'
            AND started_at &gt;= current_date - interval '7' day
          ORDER BY started_at DESC
        </relation>

        <metadata-records>
          <metadata-record class='column'>
            <remote-name>conversation_id</remote-name>
            <remote-type>129</remote-type>
            <local-name>[conversation_id]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>conversation_id</remote-alias>
            <ordinal>1</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>tenant_id</remote-name>
            <remote-type>129</remote-type>
            <local-name>[tenant_id]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>tenant_id</remote-alias>
            <ordinal>2</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>customer_key</remote-name>
            <remote-type>129</remote-type>
            <local-name>[customer_key]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>customer_key</remote-alias>
            <ordinal>3</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>agent_id</remote-name>
            <remote-type>129</remote-type>
            <local-name>[agent_id]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>agent_id</remote-alias>
            <ordinal>4</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>started_at</remote-name>
            <remote-type>7</remote-type>
            <local-name>[started_at]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>started_at</remote-alias>
            <ordinal>5</ordinal>
            <local-type>datetime</local-type>
            <aggregation>Year</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>channel_type</remote-name>
            <remote-type>129</remote-type>
            <local-name>[channel_type]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>channel_type</remote-alias>
            <ordinal>6</ordinal>
            <local-type>string</local-type>
            <aggregation>Count</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>

          <metadata-record class='column'>
            <remote-name>operator_count</remote-name>
            <remote-type>20</remote-type>
            <local-name>[operator_count]</local-name>
            <parent-name>[Custom SQL Query]</parent-name>
            <remote-alias>operator_count</remote-alias>
            <ordinal>7</ordinal>
            <local-type>integer</local-type>
            <aggregation>Sum</aggregation>
            <contains-null>true</contains-null>
          </metadata-record>
        </metadata-records>
      </connection>

      <column datatype='string' name='[agent_id]' role='dimension' type='nominal' />
      <column datatype='string' name='[channel_type]' role='dimension' type='nominal' />
      <column datatype='string' name='[conversation_id]' role='dimension' type='nominal' />
      <column datatype='string' name='[customer_key]' role='dimension' type='nominal' />
      <column datatype='integer' name='[operator_count]' role='measure' type='quantitative' />
      <column datatype='datetime' name='[started_at]' role='dimension' type='ordinal' />
      <column datatype='string' name='[tenant_id]' role='dimension' type='nominal' />
    </datasource>
  </datasources>

  <worksheets>
    <!-- Worksheet: Sentiment Trend -->
    <worksheet name='Sentiment Trend'>
      <table>
        <view>
          <datasources>
            <datasource caption='CIRL Metrics' name='athena.cirl_metrics' />
          </datasources>
          <datasource-dependencies datasource='athena.cirl_metrics'>
            <column datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[metric_name]' role='dimension' type='nominal' />
            <column datatype='real' name='[metric_value]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='None' name='[none:date:qk]' pivot='key' type='quantitative' />
            <column-instance column='[metric_value]' derivation='Avg' name='[avg:metric_value:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[athena.cirl_metrics].[metric_name]'>
            <groupfilter function='member' level='[metric_name]' member='&quot;sentiment_avg&quot;' />
          </filter>
          <slices>
            <column>[athena.cirl_metrics].[metric_name]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Automatic' />
            <encodings>
              <color column='[athena.cirl_metrics].[none:date:qk]' />
              <text column='[athena.cirl_metrics].[avg:metric_value:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[athena.cirl_metrics].[avg:metric_value:qk]</rows>
        <cols>[athena.cirl_metrics].[none:date:qk]</cols>
      </table>
    </worksheet>

    <!-- Worksheet: Daily Volume -->
    <worksheet name='Daily Volume'>
      <table>
        <view>
          <datasources>
            <datasource caption='CIRL Metrics' name='athena.cirl_metrics' />
          </datasources>
          <datasource-dependencies datasource='athena.cirl_metrics'>
            <column datatype='date' name='[date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[metric_name]' role='dimension' type='nominal' />
            <column datatype='real' name='[metric_value]' role='measure' type='quantitative' />
            <column-instance column='[date]' derivation='None' name='[none:date:qk]' pivot='key' type='quantitative' />
            <column-instance column='[metric_value]' derivation='Sum' name='[sum:metric_value:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[athena.cirl_metrics].[metric_name]'>
            <groupfilter function='member' level='[metric_name]' member='&quot;conversation_count&quot;' />
          </filter>
          <slices>
            <column>[athena.cirl_metrics].[metric_name]</column>
          </slices>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[athena.cirl_metrics].[none:date:qk]' />
              <text column='[athena.cirl_metrics].[sum:metric_value:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[athena.cirl_metrics].[sum:metric_value:qk]</rows>
        <cols>[athena.cirl_metrics].[none:date:qk]</cols>
      </table>
    </worksheet>

    <!-- Worksheet: Top Customers -->
    <worksheet name='Top Customers'>
      <table>
        <view>
          <datasources>
            <datasource caption='CIRL Conversations' name='athena.cirl_conversations' />
          </datasources>
          <datasource-dependencies datasource='athena.cirl_conversations'>
            <column datatype='string' name='[customer_key]' role='dimension' type='nominal' />
            <column datatype='string' name='[conversation_id]' role='dimension' type='nominal' />
            <column-instance column='[customer_key]' derivation='None' name='[none:customer_key:nk]' pivot='key' type='nominal' />
            <column-instance column='[conversation_id]' derivation='CountD' name='[ctd:conversation_id:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
        </view>
        <style />
        <panes>
          <pane selection-relaxation-option='selection-relaxation-allow'>
            <view>
              <breakdown value='auto' />
            </view>
            <mark class='Bar' />
            <encodings>
              <color column='[athena.cirl_conversations].[ctd:conversation_id:qk]' />
              <text column='[athena.cirl_conversations].[ctd:conversation_id:qk]' />
            </encodings>
          </pane>
        </panes>
        <rows>[athena.cirl_conversations].[none:customer_key:nk]</rows>
        <cols>[athena.cirl_conversations].[ctd:conversation_id:qk]</cols>
        <sort class='computed' column='[athena.cirl_conversations].[ctd:conversation_id:qk]' direction='DESC' />
      </table>
    </worksheet>
  </worksheets>

  <dashboards>
    <dashboard name='CIRL Overview'>
      <style />
      <size maxheight='800' maxwidth='1000' minheight='800' minwidth='1000' />
      <zones>
        <zone h='100000' id='1' type='layout-basic' w='100000' x='0' y='0'>
          <zone h='98000' id='2' param='vert' type='layout-flow' w='98000' x='1000' y='1000'>
            <zone h='32000' id='3' type='worksheet' w='98000' worksheet='Sentiment Trend' x='0' y='0' />
            <zone h='32000' id='4' type='worksheet' w='98000' worksheet='Daily Volume' x='0' y='32000' />
            <zone h='32000' id='5' type='worksheet' w='98000' worksheet='Top Customers' x='0' y='64000' />
          </zone>
        </zone>
      </zones>
    </dashboard>
  </dashboards>

  <windows>
    <window class='dashboard' name='CIRL Overview'>
      <cards>
        <edge name='left'>
          <strip size='160'>
            <card type='pages' />
            <card type='filters' />
            <card type='marks' />
          </strip>
        </edge>
      </cards>
    </window>
  </windows>
</workbook>
