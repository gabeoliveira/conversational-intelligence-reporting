              "width": 12,
              "height": 8
            }
          },
          {
            "id": "bar-1",
            "position": {
              "x": 0,
              "y": 12,
              "width": 12,
              "height": 8
            }
          },
          {
            "id": "pie-1",
            "position": {
              "x": 12,
              "y": 12,
              "width": 12,
