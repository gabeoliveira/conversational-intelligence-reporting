            }
          }
        ]
      },
      {
        "name": "Customer Insights",
        "visuals": [
          {
            "id": "table-1",
            "position": {
              "x": 0,
              "y": 0,
              "width": 12,
              "height": 12
            }
          },
          {
            "id": "table-2",
            "position": {
              "x": 12,
