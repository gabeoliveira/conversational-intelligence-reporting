            }
          },
          {
            "id": "heatmap-1",
            "position": {
              "x": 0,
              "y": 12,
              "width": 24,
              "height": 8
            }
          }
        ]
      }
    ]
  },
  "filters": [
    {
      "name": "Date Range",
      "field": "date",
      "type": "time-range",
      "defaultValue": {
        "start": "now-30d",
        "end": "now"
      },
      "appliesTo": "ALL_SHEETS"
    },
    {
      "name": "Tenant",
      "field": "tenant_id",
      "type": "list",
      "defaultValue": "{your-tenant-id}",
      "appliesTo": "ALL_SHEETS"
    }
  ],
  "notes": [
    "This is a template for reference only. QuickSight does not support direct JSON dashboard imports.",
    "To create this dashboard in QuickSight:",
    "1. Create the datasets using the SQL queries provided above",
    "2. Create a new Analysis",
    "3. Add visuals using the specifications in the 'visuals' array",
    "4. Apply filters as specified in the 'filters' array",
    "5. Organize visuals into sheets as shown in 'layout'",
    "",
    "For automated dashboard creation, consider using:",
    "- AWS CloudFormation with QuickSight resources",
    "- AWS CLI with QuickSight APIs (create-dashboard, create-template)",
    "- Terraform with QuickSight provider",
    "",
    "See QuickSight documentation for details:",
    "https://docs.aws.amazon.com/quicksight/latest/developerguide/working-with-dashboards.html"
  ]
}
